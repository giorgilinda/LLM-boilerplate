# Environment variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# -------------------------------------------------------------------
# LLM (AI) configuration
# -------------------------------------------------------------------

# Set to true to use MockLLMService during development.
# No API calls are made. Use this for all UI work to avoid burning tokens.
NEXT_PUBLIC_MOCK_MODE=true

# Which LLM model to use.
# Use a cheap/fast model during development:   claude-haiku-4-5-20251001
# Switch to the production model for quality:  claude-sonnet-4-6
NEXT_PUBLIC_LLM_MODEL=claude-haiku-4-5-20251001

# Your Anthropic API key (server-side only — never expose to the client)
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# -------------------------------------------------------------------
# Add your project-specific variables below
# -------------------------------------------------------------------
